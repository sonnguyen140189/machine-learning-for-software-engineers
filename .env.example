# ===== Claude API (caption generation) =====
ANTHROPIC_API_KEY=

# ===== Google Places API (Phu Quoc hotel/place data) =====
# https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=

# ===== Unsplash (free stock photos) =====
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ===== Pexels (free stock photos / videos) =====
# https://www.pexels.com/api/
PEXELS_API_KEY=

# ===== Meta Graph API (Facebook + Instagram) =====
# Long-lived Page access token. Page must be linked to an IG Business account.
# https://developers.facebook.com/docs/instagram-api/getting-started
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_BUSINESS_ACCOUNT_ID=

# ===== TikTok Content Posting API =====
# https://developers.tiktok.com/doc/content-posting-api-get-started
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ===== Public CDN for media (TikTok + IG require public URLs) =====
# Either GitHub Pages of this repo or any public bucket (S3/R2/Supabase Storage).
# Pipeline will upload generated media here and pass the URL to the post APIs.
PUBLIC_MEDIA_BASE_URL=

# ===== Run flags =====
DRY_RUN=true
TIMEZONE=Asia/Ho_Chi_Minh
